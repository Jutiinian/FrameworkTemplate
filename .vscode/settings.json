{
  // -- Stylua -------------------------------------------
  "stylua.targetReleaseVersion": "latest",

  // -- Formatting ----------------------------------------
  "[lua]": {
    "editor.defaultFormatter": "JohnnyMorganz.stylua",
    "editor.formatOnSave": true
  },
  "[luau]": {
    "editor.defaultFormatter": "JohnnyMorganz.stylua",
    "editor.formatOnSave": true
  },

  // -- Luau LSP -------------------------------------------
  "luau-lsp.completion.enabled": true,
  "luau-lsp.completion.imports.enabled": true,
  "luau-lsp.completion.autocompleteEnd": true,
  "luau-lsp.completion.addParentheses": true,
  "luau-lsp.completion.imports.separateGroupsWithLine": true,
  "luau-lsp.completion.showKeywords": true,
  "luau-lsp.hover.strictDatamodelTypes": true,
  "luau-lsp.diagnostics.strictDatamodelTypes": true,
  "luau-lsp.diagnostics.pullOnChange": true,
  "luau-lsp.diagnostics.pullOnSave": true,
  "luau-lsp.platform.type": "roblox",
  "luau-lsp.sourcemap.autogenerate": true,
  "luau-lsp.sourcemap.rojoProjectFile": "default.project.json",
  "luau-lsp.sourcemap.sourcemapFile": "sourcemap.json",

  // -- Search -------------------------------------------
  "search.exclude": {
    "**/Packages": true,
    "**/ServerPackages": true
  }
}
